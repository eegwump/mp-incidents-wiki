DEBUG=False
PORT=5000
FLASK_ENV=production

# Slack Configuration (Optional)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
INCIDENTS_CHANNEL=incidents

# Email Configuration (Optional - use if Slack is not available)
EMAIL_PROVIDER=gmail  # gmail, sendgrid, aws_ses, smtp
EMAIL_FROM=incidents@example.com
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
# For Gmail: use App Password, not your regular password
# For SendGrid: set EMAIL_USERNAME=apikey, EMAIL_PASSWORD=your-sendgrid-key
# For AWS SES: set EMAIL_USERNAME=access-key-id, EMAIL_PASSWORD=secret-access-key
# For custom SMTP: set SMTP_HOST, SMTP_PORT
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Default notification email addresses (comma-separated)
INCIDENT_EMAIL_RECIPIENTS=team@example.com,oncall@example.com
